# Secrets
.env
.env.*
!.env.example

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
.venv/
venv/
env/

# Cache (auto-managed)
# NB: we ignore *contents* of data/cache/ rather than the directory
# itself, so the L3.5A HMM carve-outs below can re-include specific
# committed artifacts. (Per spec §3.5A-3.3-1.)
data/cache/*
data/derived/
data/output/

# L3.5A — HMM frozen artifact MUST be committed (sidecar + pickle).
# This carve-out is the spec-locked exception to ``data/cache/*`` rule.
!data/cache/hmm/
!data/cache/hmm/*.pkl
!data/cache/hmm/*.meta.json

# Raw data (large; users provide their own)
data/raw/

# L10 web app runtime artifacts (user uploads + rendered reports)
data/uploads/
data/forecasts/webapp_renders/

# Data file formats
*.parquet

# Local scratch (catalogs, prompts, zip backups)
save/

# Claude Code local-only settings (personal overrides)
.claude/settings.local.json

# Tooling
.pytest_cache/
.mypy_cache/
.ruff_cache/
.ipynb_checkpoints/

# Worktree-local pip --target install dir (L3.5A);
# real deps are declared in pyproject.toml + uv.lock.
.local-deps/

# HMM lockfile created by filelock during loads (L3.5A)
*.pkl.lock

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db
