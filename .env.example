# L12 v2 — environment template. Copy to `.env` (not committed) and fill in.

# FRED API key — required for auto-fetching unemployment, payrolls, fed funds.
# Free registration (~1 minute) at:
#   https://fred.stlouisfed.org/docs/api/api_key.html
# When the key is missing the webapp still works — the 3 FRED-backed form
# fields render as manual inputs and you fill them yourself.
FRED_API_KEY=<your-key-here>

# Optional: override the Yahoo Finance ticker for S&P 500 current price.
# Default is ^GSPC (the S&P 500 index). Other reasonable values: SPY (ETF
# proxy with continuous quote during US market hours).
# YAHOO_TICKER_SP500=^GSPC
